FROM node:22-bookworm-slim AS deps

ARG APT_MIRROR=

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable
WORKDIR /app
RUN pnpm config set registry https://registry.npmmirror.com

RUN set -eux; \
  printf '%s\n' \
    'Acquire::Retries "5";' \
    'Acquire::http::Timeout "30";' \
    'Acquire::https::Timeout "30";' \
    > /etc/apt/apt.conf.d/80-retries-timeouts; \
  apt_install() { \
    for attempt in 1 2 3; do \
      apt-get update \
        && apt-get install -y --no-install-recommends --fix-missing "$@" \
        && return 0; \
      if [ "$attempt" = "3" ]; then \
        return 1; \
      fi; \
      rm -rf /var/lib/apt/lists/*; \
      sleep $((attempt * 5)); \
    done; \
  }; \
  if [ -n "$APT_MIRROR" ]; then \
    apt_install ca-certificates; \
    rm -rf /var/lib/apt/lists/*; \
    mirror="${APT_MIRROR%/}"; \
    sed -i -E \
      -e "s|https?://deb.debian.org/debian-security|${mirror}/debian-security|g" \
      -e "s|https?://security.debian.org/debian-security|${mirror}/debian-security|g" \
      -e "s|https?://deb.debian.org/debian|${mirror}/debian|g" \
      /etc/apt/sources.list.d/debian.sources; \
    apt_install python3 make g++; \
  else \
    apt_install ca-certificates python3 make g++; \
  fi; \
  rm -rf /var/lib/apt/lists/*

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json
COPY packages/ui/package.json packages/ui/package.json
COPY packages/config/package.json packages/config/package.json

RUN pnpm --filter @jinhu/web... install --frozen-lockfile

FROM deps AS build

ARG NEXT_PUBLIC_API_TARGET=http://api:3001
ARG NEXT_PUBLIC_API_PREFIX=/api/v1
ENV NEXT_PUBLIC_API_TARGET=$NEXT_PUBLIC_API_TARGET
ENV NEXT_PUBLIC_API_PREFIX=$NEXT_PUBLIC_API_PREFIX

COPY . .
RUN pnpm --filter @jinhu/shared build
RUN pnpm --filter @jinhu/web build

FROM node:22-bookworm-slim AS runtime

ENV NODE_ENV=production
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable
WORKDIR /app

COPY --from=build /app/package.json ./package.json
COPY --from=build /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=build /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/web ./apps/web
COPY --from=build /app/packages ./packages

EXPOSE 3000
CMD ["pnpm", "--filter", "@jinhu/web", "start"]
