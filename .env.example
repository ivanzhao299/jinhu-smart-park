# Base runtime
NODE_ENV=development
APP_ENV=local
APP_PORT=3001
WEB_PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jinhu_smart_park
POSTGRES_USER=jinhu
POSTGRES_PASSWORD=change_me

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h
AUTH_REFRESH_EXPIRES_DAYS=30
AUTH_LOGIN_TICKET_TTL_SECONDS=300
AUTH_OAUTH_STATE_TTL_SECONDS=300
BCRYPT_SALT_ROUNDS=12

# API
API_PREFIX=api/v1
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_PREFIX=/api/v1
NEXT_PUBLIC_API_TARGET=http://127.0.0.1:3101

# Idempotency cleanup
IDEMPOTENCY_CLEANUP_ENABLED=true
IDEMPOTENCY_CLEANUP_INTERVAL_MS=3600000
IDEMPOTENCY_CLEANUP_BATCH_SIZE=1000

# File storage for local development only.
FILE_STORAGE_LOCAL_ROOT=storage/files

# Local development only: SMS login mock
AUTH_SMS_FIXED_CODE=123456
AUTH_SMS_CODE_VISIBLE=true
AUTH_SMS_RESEND_SECONDS=60
AUTH_SMS_CODE_TTL_SECONDS=300

# Local development only: WeChat login mock
AUTH_WECHAT_MOCK_ENABLED=true
AUTH_WECHAT_APP_ID=
AUTH_WECHAT_APP_SECRET=
AUTH_WECHAT_REDIRECT_URI=http://localhost:3000/login
AUTH_WECHAT_ALLOWED_REDIRECT_ORIGINS=http://localhost:3000
AUTH_WECHAT_AUTHORIZE_URL=https://open.weixin.qq.com/connect/qrconnect
AUTH_WECHAT_SCOPE=snsapi_login

# SaaS baseline
DEFAULT_TENANT_CODE=JH_DEFAULT
DEFAULT_TENANT_ID=10000001
DEFAULT_PARK_ID=20000001
CODE_RULE_DEFAULT_DATE_PATTERN=yyyyMMdd
CODE_RULE_DEFAULT_SEQUENCE_LENGTH=6

# TimescaleDB
TIMESCALE_URL=postgresql://user:pass@localhost:5432/smartpark

# Redis
REDIS_URL=redis://localhost:6379

# EMQX / MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=smartpark
MQTT_PASSWORD=change_me
IOT_RULE_WEBHOOK_ALLOWLIST=localhost,127.0.0.1
IOT_HEARTBEAT_TIMEOUT_SECONDS=120
IOT_DEVICE_SECRET_ENCRYPTION_KEY=

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Video
VIDEO_SECRET_ENCRYPTION_KEY=
VIDEO_ALERT_SCHEDULER_ENABLED=false
VIDEO_ALERT_SCHEDULER_INTERVAL_MS=60000

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=smartpark

# AI
AI_PROVIDER=openai
AI_API_KEY=change_me
AI_MODEL=gpt-4o
