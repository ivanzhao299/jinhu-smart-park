NODE_ENV=production

# Published host ports. Change these if the server already uses 3000/3001/5432.
WEB_PUBLISHED_PORT=3000
API_PUBLISHED_PORT=3001
POSTGRES_PUBLISHED_PORT=5432

APP_PORT=3001
WEB_PORT=3000
API_PREFIX=api/v1

# Browser origin allowed by API CORS.
WEB_ORIGIN=https://your-domain.example

# Next.js server-side rewrite target inside the docker network.
NEXT_PUBLIC_API_TARGET=http://api:3001
NEXT_PUBLIC_API_PREFIX=/api/v1

POSTGRES_DB=jinhu_smart_park
POSTGRES_USER=jinhu
POSTGRES_PASSWORD=change_me_use_a_strong_database_password

JWT_SECRET=change_me_use_at_least_32_random_characters
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

DEFAULT_TENANT_CODE=jinhu
DEFAULT_TENANT_ID=10000001
DEFAULT_PARK_ID=20000001

# Optional infrastructure. Leave blank only for first validation deployments.
REDIS_URL=
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
RABBITMQ_URL=
TIMESCALE_URL=
IOT_RULE_WEBHOOK_ALLOWLIST=

MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jinhu-smart-park

AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_DEFAULT_MODEL=

# First deployment only. Set to yes if the production core seed should run.
RUN_PRODUCTION_SEED=no
