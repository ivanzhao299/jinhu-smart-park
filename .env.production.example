# Base runtime
NODE_ENV=production
APP_ENV=production

# Published host ports. Change these if the server already uses 3000/3001/5432.
WEB_PUBLISHED_PORT=3000
API_PUBLISHED_HOST=127.0.0.1
API_PUBLISHED_PORT=3001
POSTGRES_PUBLISHED_PORT=5432

APP_PORT=3001
WEB_PORT=3000
API_PREFIX=api/v1
WEB_ORIGIN=https://your-domain.example
NEXT_PUBLIC_API_PREFIX=/api/v1

# Next.js server-side rewrite target inside the docker network.
NEXT_PUBLIC_API_TARGET=http://api:3001

# Optional Docker build mirror. Keep blank unless the production host has slow access
# to Debian package repositories, e.g. https://mirrors.aliyun.com.
APT_MIRROR=

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jinhu_smart_park
POSTGRES_USER=jinhu
POSTGRES_PASSWORD=change_me_use_a_strong_database_password

# Idempotency cleanup
IDEMPOTENCY_CLEANUP_ENABLED=true
IDEMPOTENCY_CLEANUP_INTERVAL_MS=3600000
IDEMPOTENCY_CLEANUP_BATCH_SIZE=1000

# Authentication
JWT_SECRET=change_me_use_at_least_32_random_characters
JWT_EXPIRES_IN=8h
AUTH_REFRESH_EXPIRES_DAYS=30
AUTH_LOGIN_TICKET_TTL_SECONDS=300
AUTH_OAUTH_STATE_TTL_SECONDS=300
BCRYPT_SALT_ROUNDS=10

# Auth public endpoint rate limiting. Credential buckets are enabled by default.
# APP_TRUST_PROXY and IP-only buckets must only be enabled when the trusted proxy
# chain strips or overwrites incoming X-Forwarded-For before requests reach API.
APP_TRUST_PROXY=
AUTH_RATE_LIMIT_MAX_BUCKETS=10000
AUTH_RATE_LIMIT_IP_BUCKETS_ENABLED=false
AUTH_RATE_LIMIT_LOGIN_LIMIT=60
AUTH_RATE_LIMIT_LOGIN_WINDOW_MS=60000
AUTH_RATE_LIMIT_LOGIN_STABLE_LIMIT=300
AUTH_RATE_LIMIT_LOGIN_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_LOGIN_IP_LIMIT=100
AUTH_RATE_LIMIT_LOGIN_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_TOKEN_REFRESH_LIMIT=60
AUTH_RATE_LIMIT_TOKEN_REFRESH_WINDOW_MS=60000
AUTH_RATE_LIMIT_TOKEN_REFRESH_STABLE_LIMIT=300
AUTH_RATE_LIMIT_TOKEN_REFRESH_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_TOKEN_REFRESH_IP_LIMIT=300
AUTH_RATE_LIMIT_TOKEN_REFRESH_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_SELECT_CONTEXT_LIMIT=30
AUTH_RATE_LIMIT_SELECT_CONTEXT_WINDOW_MS=60000
AUTH_RATE_LIMIT_SELECT_CONTEXT_STABLE_LIMIT=150
AUTH_RATE_LIMIT_SELECT_CONTEXT_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_SELECT_CONTEXT_IP_LIMIT=150
AUTH_RATE_LIMIT_SELECT_CONTEXT_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_LIMIT=5
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_STABLE_LIMIT=60
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_IP_LIMIT=30
AUTH_RATE_LIMIT_MOBILE_SEND_CODE_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_LOGIN_LIMIT=20
AUTH_RATE_LIMIT_MOBILE_LOGIN_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_LOGIN_STABLE_LIMIT=150
AUTH_RATE_LIMIT_MOBILE_LOGIN_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_MOBILE_LOGIN_IP_LIMIT=100
AUTH_RATE_LIMIT_MOBILE_LOGIN_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_LIMIT=20
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_STABLE_LIMIT=150
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_IP_LIMIT=100
AUTH_RATE_LIMIT_WECHAT_AUTHORIZE_IP_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_CALLBACK_LIMIT=20
AUTH_RATE_LIMIT_WECHAT_CALLBACK_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_CALLBACK_STABLE_LIMIT=150
AUTH_RATE_LIMIT_WECHAT_CALLBACK_STABLE_WINDOW_MS=60000
AUTH_RATE_LIMIT_WECHAT_CALLBACK_IP_LIMIT=100
AUTH_RATE_LIMIT_WECHAT_CALLBACK_IP_WINDOW_MS=60000

# File storage. Keep this aligned with the API volume mount in docker-compose.prod.yml.
FILE_STORAGE_LOCAL_ROOT=/var/lib/jinhu/files

# Release baseline
DEFAULT_TENANT_CODE=jinhu
DEFAULT_TENANT_ID=10000001
DEFAULT_PARK_ID=20000001

# Release disabled: SMS login must remain off in production.
AUTH_SMS_FIXED_CODE=
AUTH_SMS_CODE_VISIBLE=false
AUTH_SMS_RESEND_SECONDS=60
AUTH_SMS_CODE_TTL_SECONDS=300

# Release disabled: WeChat login must remain off in production.
AUTH_WECHAT_MOCK_ENABLED=false
AUTH_WECHAT_APP_ID=
AUTH_WECHAT_APP_SECRET=
AUTH_WECHAT_REDIRECT_URI=
AUTH_WECHAT_ALLOWED_REDIRECT_ORIGINS=
AUTH_WECHAT_AUTHORIZE_URL=
AUTH_WECHAT_SCOPE=

# Optional infrastructure. Leave blank only for first validation deployments.
REDIS_URL=
RABBITMQ_URL=
TIMESCALE_URL=

# Non-release integrations. Keep blank when not enabled.
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
IOT_RULE_WEBHOOK_ALLOWLIST=
IOT_HEARTBEAT_TIMEOUT_SECONDS=
IOT_DEVICE_SECRET_ENCRYPTION_KEY=
VIDEO_SECRET_ENCRYPTION_KEY=
VIDEO_ALERT_SCHEDULER_ENABLED=
VIDEO_ALERT_SCHEDULER_INTERVAL_MS=

MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=jinhu-smart-park

AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_DEFAULT_MODEL=

# First deployment only. Set to yes if the production core seed should run.
RUN_PRODUCTION_SEED=no
