{
  "name": "jinhu-smart-park",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @jinhu/web dev",
    "dev:api": "pnpm --filter @jinhu/api start:dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm run test:e2e",
    "test:unit": "pnpm --filter @jinhu/api test:unit",
    "test:coverage": "pnpm --filter @jinhu/api test:coverage",
    "test:e2e": "node scripts/e2e/s1-smoke.mjs && node scripts/e2e/s1-rbac-std-fix-smoke.mjs && node scripts/e2e/s2b-smoke.mjs && node scripts/e2e/s3a-park-tenant-smoke.mjs && node scripts/e2e/s3b-leasing-crm-smoke.mjs && node scripts/e2e/s3c-contract-smoke.mjs && node scripts/e2e/s3d-payment-smoke.mjs && node scripts/e2e/s3d-waiver-smoke.mjs && node scripts/e2e/s3d-invoice-smoke.mjs && node scripts/e2e/s3e-contract-lifecycle-smoke.mjs && node scripts/e2e/s5a-safety-smoke.mjs && node scripts/e2e/s5b-emergency-permit-smoke.mjs",
    "test:e2e:s1-rbac-std-fix": "node scripts/e2e/s1-rbac-std-fix-smoke.mjs",
    "test:e2e:s2b": "node scripts/e2e/s2b-smoke.mjs",
    "test:e2e:s3a-park-tenant": "node scripts/e2e/s3a-park-tenant-smoke.mjs",
    "test:e2e:s3b-leasing-crm": "node scripts/e2e/s3b-leasing-crm-smoke.mjs",
    "test:e2e:s3c-contract": "node scripts/e2e/s3c-contract-smoke.mjs",
    "test:e2e:s3d-payment": "node scripts/e2e/s3d-payment-smoke.mjs",
    "test:e2e:s3d-waiver": "node scripts/e2e/s3d-waiver-smoke.mjs",
    "test:e2e:s3d-invoice": "node scripts/e2e/s3d-invoice-smoke.mjs",
    "test:e2e:s3e-contract-lifecycle": "node scripts/e2e/s3e-contract-lifecycle-smoke.mjs",
    "test:e2e:s5a-safety": "node scripts/e2e/s5a-safety-smoke.mjs",
    "test:e2e:s5b-emergency-permit": "node scripts/e2e/s5b-emergency-permit-smoke.mjs",
    "safety:smoke:access": "node scripts/e2e/safety-module-access-smoke.mjs",
    "safety:fixtures:access": "node scripts/e2e/prepare-safety-access-smoke-fixtures.mjs",
    "test:e2e:s8c-video-camera": "node scripts/e2e/s8c-video-camera-smoke.mjs",
    "test:e2e:s8d-video-preview-platform": "node scripts/e2e/s8d-video-preview-platform-smoke.mjs",
    "test:e2e:s8e-video-evidence-inspection": "node scripts/e2e/s8e-video-evidence-inspection-smoke.mjs",
    "test:e2e:s8f-video-alert-dashboard": "node scripts/e2e/s8f-video-alert-dashboard-smoke.mjs",
    "test:e2e:s9a-iot-device-hub": "node scripts/e2e/s9a-iot-device-hub-smoke.mjs",
    "test:e2e:s9b-iot-runtime-alert": "node scripts/e2e/s9b-iot-runtime-alert-smoke.mjs",
    "test:e2e:s9c-iot-rule-engine": "node scripts/e2e/s9c-iot-rule-engine-smoke.mjs",
    "test:e2e:s9d-iot-scene-center": "node scripts/e2e/s9d-iot-scene-center-smoke.mjs",
    "test:e2e:s9d1-unified-action-executor": "node scripts/e2e/s9d1-unified-action-executor-smoke.mjs",
    "test:e2e:s9e-energy-meter-monitor": "node scripts/e2e/s9e-energy-meter-monitor-smoke.mjs",
    "test:e2e:s9f-energy-billing-tenant": "node scripts/e2e/s9f-energy-billing-tenant-smoke.mjs",
    "test:e2e:s9f1-energy-billing-adjustment-reversal": "node scripts/e2e/s9f1-energy-billing-adjustment-reversal-smoke.mjs",
    "smoke:cleanup": "sh scripts/smoke-cleanup.sh",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:migrate": "sh scripts/db-migrate.sh",
    "db:check:init": "sh scripts/check-init-baseline.sh",
    "db:bootstrap:admin": "sh scripts/bootstrap-admin.sh",
    "db:seed": "sh scripts/db-seed-prod.sh",
    "db:seed:dev": "sh scripts/db-seed-dev.sh",
    "db:seed:prod": "sh scripts/db-seed-prod.sh",
    "prod:deploy": "sh scripts/prod-deploy.sh",
    "prod:cleanup": "sh scripts/prod-docker-cleanup.sh",
    "prod:health": "sh scripts/prod-healthcheck.sh",
    "prod:up": "docker compose --env-file .env.production -f infra/docker/docker-compose.prod.yml up -d",
    "prod:down": "docker compose --env-file .env.production -f infra/docker/docker-compose.prod.yml down",
    "go-live:check": "node scripts/go-live-readiness-check.mjs",
    "go-live:p0-check": "node scripts/go-live-p0-check.mjs",
    "go-live:uat-login": "node scripts/go-live-uat-user-login-check.mjs",
    "go-live:uat-all": "node scripts/go-live-uat-user-login-check.mjs --all-users",
    "go-live:uat-role-flow": "node scripts/go-live-role-flow-uat.mjs",
    "go-live:uat-browser": "node scripts/go-live-browser-uat-check.mjs",
    "go-live:uat-engineering-terminal-click": "node scripts/engineering-terminal-click-uat.mjs",
    "go-live:uat-engineering-terminal-form": "node scripts/engineering-terminal-form-uat.mjs",
    "css:check": "node scripts/check-css-architecture.mjs",
    "check:s1": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@jinhu/config": "workspace:*",
    "@eslint/js": "^9.16.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
