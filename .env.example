# Shared
NODE_ENV=development
APP_PORT=3001
WEB_PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jinhu_smart_park
POSTGRES_USER=jinhu
POSTGRES_PASSWORD=change_me

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h
BCRYPT_SALT_ROUNDS=12

# API
API_PREFIX=/api/v1
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_PREFIX=/api/v1

# SaaS baseline
DEFAULT_TENANT_CODE=JH_DEFAULT
DEFAULT_TENANT_ID=10000001
DEFAULT_PARK_ID=20000001
CODE_RULE_DEFAULT_DATE_PATTERN=yyyyMMdd
CODE_RULE_DEFAULT_SEQUENCE_LENGTH=6

# TimescaleDB
TIMESCALE_URL=postgresql://user:pass@localhost:5432/smartpark

# Redis
REDIS_URL=redis://localhost:6379

# EMQX / MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=smartpark
MQTT_PASSWORD=change_me
IOT_RULE_WEBHOOK_ALLOWLIST=localhost,127.0.0.1

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=smartpark

# AI
AI_PROVIDER=openai
AI_API_KEY=change_me
AI_MODEL=gpt-4o
