{
  "version": 1,
  "updated_at": "2026-06-22T13:10:00.000Z",
  "purpose": "Route natural-language requirements to a stable agent owner before task-queue generation.",
  "routing_policy": {
    "selection_order": [
      "explicit_agent_mention",
      "keyword_match",
      "domain_match",
      "fallback_rules",
      "fallback_priority"
    ],
    "owner_requirement": "Every generated task must set owner from these rules unless the user explicitly overrides ownership.",
    "path_policy": "Router rules choose the owner and default low-risk output paths. Any task that expands into apps, packages, database, infra, auth, CI, Docker, deploy, migration, seed, or production operations must mark requires_human_approval=true and receive explicit user approval before execution."
  },
  "default_forbidden_paths": [
    "apps/**",
    "packages/**",
    "database/**",
    "infra/**",
    ".github/**",
    "Dockerfile",
    "Dockerfile.*",
    "docker-compose*",
    "deploy/**",
    "auth/**",
    ".env",
    ".env.*"
  ],
